#!/usr/bin/env bash
# PostToolUse hook for Agent tool.
#
# Historically this decremented the active-subagent counter. That was a
# latent landmine for BACKGROUND subagents: the Agent tool call returns
# immediately (the subagent is still running), so decrementing here
# drained the counter to 0 mid-run. The decrement now lives on the
# SubagentStop event (see hooks/subagent-stop), which fires only when
# the subagent actually finishes. This hook is retained as a no-op
# router target so the PostToolUse:Agent matcher stays valid.
set -uo pipefail

exit 0
