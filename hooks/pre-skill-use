#!/usr/bin/env bash
# PreToolUse hook for Skill tool — creates markers when PM skills are loaded
set -uo pipefail

SUFFIX="${UID:-$(id -u 2>/dev/null || echo 0)}"
MARKER_DIR="${XDG_RUNTIME_DIR:-/tmp}"
PM_LOADED="${MARKER_DIR}/.dev-team-pm-loaded-${SUFFIX}"
PM_RESTRICTED="${MARKER_DIR}/.dev-team-pm-restricted-${SUFFIX}"

# Read tool call details from stdin (JSON with tool input)
INPUT=$(cat 2>/dev/null || true)
[ -z "$INPUT" ] && exit 0

# Extract skill name — try jq first (exact parsing), fallback to grep
skill=""
if command -v jq &>/dev/null; then
    skill=$(echo "$INPUT" | jq -r '.tool_input.skill // .skill // empty' 2>/dev/null)
fi
if [ -z "$skill" ]; then
    skill=$(echo "$INPUT" | grep -oE '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' 2>/dev/null | head -1 | sed 's/.*:.*"\([^"]*\)"$/\1/')
fi

# Create markers when development-team:pm is loaded
# PM voluntarily activates restriction by loading its skill
if [ "$skill" = "development-team:pm" ]; then
    if ! touch "$PM_LOADED" 2>/dev/null; then
        echo "development-team hook: failed to create marker $PM_LOADED" >&2
    fi
    if ! touch "$PM_RESTRICTED" 2>/dev/null; then
        echo "development-team hook: failed to create restriction marker $PM_RESTRICTED" >&2
    fi
fi

# Always allow Skill tool calls
exit 0
