#!/usr/bin/env bash
# SessionStart hook for development-team plugin

set -euo pipefail

# Read SessionStart stdin to derive a per-session key. Markers keyed only by
# UID collide across concurrent same-user sessions and across /tmp lifetime;
# keying by session_id isolates each session. session_id is sanitized to
# [A-Za-z0-9_-] (path-traversal-safe); absent/invalid -> "nosession".
_INPUT="$(cat 2>/dev/null || true)"
_MARKER_DIR="${XDG_RUNTIME_DIR:-/tmp}"
_dt_uid="${UID:-$(id -u 2>/dev/null || echo 0)}"
_dt_skey=""
if [ -n "${_INPUT:-}" ]; then
    if command -v jq >/dev/null 2>&1; then
        _dt_skey="$(printf '%s' "$_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)"
    fi
    if [ -z "$_dt_skey" ]; then
        _dt_skey="$(printf '%s' "$_INPUT" | grep -oE '"session_id"[[:space:]]*:[[:space:]]*"[^"]*"' 2>/dev/null | head -1 | sed 's/.*"\([^"]*\)"$/\1/' || true)"
    fi
fi
_dt_skey="$(printf '%s' "$_dt_skey" | tr -cd 'A-Za-z0-9_-' 2>/dev/null || true)"
if [ -z "$_dt_skey" ]; then _dt_skey="nosession"; fi
_MARKER_SUFFIX="${_dt_uid}-${_dt_skey}"
unset _dt_uid _dt_skey _INPUT

# Start each session clean: clear THIS session's PM markers + active counter
# (removes crash-orphans from any prior run of the same session_id), then stamp
# the session marker so pre-tool-use can compare PM_RESTRICTED vs SESSION mtimes.
rm -f "${_MARKER_DIR}/.dev-team-pm-loaded-${_MARKER_SUFFIX}" 2>/dev/null || true
rm -f "${_MARKER_DIR}/.dev-team-pm-restricted-${_MARKER_SUFFIX}" 2>/dev/null || true
rm -rf "${_MARKER_DIR}/.dev-team-active-${_MARKER_SUFFIX}" 2>/dev/null || true
touch "${_MARKER_DIR}/.dev-team-session-${_MARKER_SUFFIX}" 2>/dev/null || true

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read bootstrap content
bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/development-team/bootstrap.md" 2>&1 || echo "Error reading development-team bootstrap")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have the development-team skill available.\n\n**Below is the bootstrap context for your 'development-team' skill - your introduction to the IT project manager operating mode. Regardless of what the user asked, you MUST load BOTH skills via the Skill tool FIRST, before anything else: 1) development-team:pm  2) development-team.**\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
# Claude Code reads BOTH additional_context and hookSpecificOutput without
# deduplication, so we must emit only the field the current platform consumes.
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT)
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT without COPILOT_CLI
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Copilot CLI (sets COPILOT_CLI=1) or unknown platform — SDK standard format
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
